# 本地开发环境变量模板
# 复制为 .env 后填入实际值

# ==========================================
# 后端配置
# ==========================================

# 服务器配置
SERVER_PORT=8080
SERVER_MODE=debug
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=template_db
DB_SSLMODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-256-bit-secret-key-here
JWT_ACCESS_EXPIRE=2
JWT_REFRESH_EXPIRE=168

# ==========================================
# 前端配置
# ==========================================

# API 基础地址
VITE_API_BASE_URL=/api

# 应用环境
VITE_APP_ENV=development
