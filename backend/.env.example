# Server
SERVER_PORT=8080
SERVER_MODE=debug
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
